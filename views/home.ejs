<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>CritClass Home</title>
    <link rel="stylesheet" href="/css/style.css" />
  </head>
  <body>
    <div class="page-shell dashboard-shell">
      <header class="hero dashboard-hero">
        <a href="/logout" class="secondary-btn signout-btn">Sign Out</a>
        <form id="searchForm" class="header-search">
          <input id="searchInput" class="search-input" type="search" placeholder="Search classes, teachers, or reviews" aria-label="Search" />
          <button type="submit" class="primary-btn search-button">Search</button>
        </form>
        <button id="showAllBtn" class="secondary-btn" style="margin-top: 1rem;">Show all</button>
        <div id="searchResults" class="search-results" aria-live="polite"></div>
        <% if (sections && sections.length) { %>
        <div class="quick-access-grid">
          <% sections.forEach(function(s) { %>
            <a href="/class/<%= s.id %>" class="quick-access-link">
              <div class="quick-access-box">
                <h3><%= s.courseName %></h3>
                <p><%= s.teacherFirstName %> <%= s.teacherLastName %></p>
              </div>
            </a>
          <% }); %>
        </div>
        <% } %>
      </header>
    </div>
    <script src="/js/dashboard.js"></script>
  </body>
</html>
